{
  "version": "2.0",
  "$schema": "https://framework-1258016615.tcloudbaseapp.com/schema/latest.json",
  "envId": "{{envId}}",
  "framework": {
    "name": "rongzhi-assistant",
    "plugins": {}
  },
  "functions": [
    {
      "name": "user-register",
      "handler": "user/register.main",
      "runtime": "Nodejs16.13",
      "memorySize": 256,
      "timeout": 10,
      "environmentVariables": {},
      "vpc": {
        "vpcId": "{{vpcId}}",
        "subnetId": "{{subnetId}}"
      }
    },
    {
      "name": "user-login",
      "handler": "user/login.main",
      "runtime": "Nodejs16.13",
      "memorySize": 256,
      "timeout": 10,
      "environmentVariables": {},
      "vpc": {
        "vpcId": "{{vpcId}}",
        "subnetId": "{{subnetId}}"
      }
    },
    {
      "name": "user-profile",
      "handler": "user/profile.main",
      "runtime": "Nodejs16.13",
      "memorySize": 256,
      "timeout": 10,
      "environmentVariables": {},
      "vpc": {
        "vpcId": "{{vpcId}}",
        "subnetId": "{{subnetId}}"
      }
    },
    {
      "name": "user-logout",
      "handler": "user/logout.main",
      "runtime": "Nodejs16.13",
      "memorySize": 256,
      "timeout": 5,
      "environmentVariables": {},
      "vpc": {
        "vpcId": "{{vpcId}}",
        "subnetId": "{{subnetId}}"
      }
    },
    {
      "name": "user-sms",
      "handler": "user/sms.main",
