        "subnetId": "{{subnetId}}"
      }
    },
    {
      "name": "member-subscribe",
      "handler": "member/subscribe.main",
      "runtime": "Nodejs16.13",
      "memorySize": 256,
      "timeout": 15,
      "environmentVariables": {},
      "vpc": {
        "vpcId": "{{vpcId}}",
        "subnetId": "{{subnetId}}"
      }
