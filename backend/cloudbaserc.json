      "environmentVariables": {
        "AI_API_KEY": "{{aiApiKey}}",
        "AI_MODEL": "{{aiModel}}"
      },
      "vpc": {
        "vpcId": "{{vpcId}}",
        "subnetId": "{{subnetId}}"
