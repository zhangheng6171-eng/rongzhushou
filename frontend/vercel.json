{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/auth/$1"
    },
    {
      "src": "/api/user/(.*)",
      "dest": "/api/user/$1"
    },
    {
      "src": "/api/ai/(.*)",
      "dest": "/api/ai/$1"
    },
    {
      "src": "/api/loan/(.*)",
      "dest": "/api/loan/$1"
    },
    {
      "src": "/api/article/(.*)",
      "dest": "/api/article/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    }
  ],
  "env": {
    "JWT_SECRET": "rongzhushou-secret-key-2026"
  }
}
